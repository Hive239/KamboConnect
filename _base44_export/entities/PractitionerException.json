        "override",
        "additional",
        "remove"
      ],
      "description": "Override normal hours, add extra availability, or remove availability"
    },
    "start_time": {
      "type": "string",
      "description": "Exception start time in HH:MM format"
    },
    "end_time": {
      "type": "string",
      "description": "Exception end time in HH:MM format"
    },
    "notes": {
      "type": "string",
