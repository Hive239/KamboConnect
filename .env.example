# Copy to .env (gitignored) and fill in from Supabase → Project Settings → API.
# The anon/public key is safe to expose in the browser (RLS protects data).
VITE_SUPABASE_URL=https://ehqsudxguigezjaygsrr.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# SERVER-SIDE ONLY — never commit real values, never use in the frontend:
# SUPABASE_SERVICE_ROLE_KEY=...
# DATABASE_URL=postgresql://postgres:...@db.<ref>.supabase.co:5432/postgres

# OPTIONAL — error monitoring. If set, the app lazy-loads @sentry/browser and
# reports uncaught errors. Leave unset to disable (reportError stays console-only).
# Requires: npm i @sentry/browser
# VITE_SENTRY_DSN=https://...@o000000.ingest.sentry.io/000000

# ─────────────────────────────────────────────────────────────────────────────
# PAYMENTS (Stripe). With no keys the app uses a built-in mock so checkout still
# works for demos. Set ALL of these to switch Market + subscriptions to real
# Stripe Checkout (booking deposits use the mock until a dedicated deposit flow):
#   VITE_STRIPE_PUBLISHABLE_KEY  — client flag that payments are live (pk_live/pk_test)
#   STRIPE_SECRET_KEY            — server (api/stripe-checkout.js) — sk_live/sk_test
#   STRIPE_WEBHOOK_SECRET        — server (api/stripe-webhook.js) — whsec_...
# The webhook writes paid records via the service role, so it also needs
# SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY (below).
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ─────────────────────────────────────────────────────────────────────────────
# WEB PUSH (api/push-send.js). Generate with `npx web-push generate-vapid-keys`.
# VITE_VAPID_PUBLIC_KEY=...
# VAPID_PRIVATE_KEY=...
# VAPID_SUBJECT=mailto:you@kamboguide.com

# ─────────────────────────────────────────────────────────────────────────────
# EMAIL (api/send-email.js). Set for transactional email (reminders, digests).
# EMAIL_PROVIDER_API_KEY=...
# EMAIL_FROM=hello@kamboguide.com

# ─────────────────────────────────────────────────────────────────────────────
# SERVER-SIDE ONLY — never expose to the browser. Used by the /api functions
# (stripe-webhook, delete-account, reminders) to write with RLS bypassed.
# SUPABASE_URL=https://ehqsudxguigezjaygsrr.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=...
